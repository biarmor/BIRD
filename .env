# BIRD Backend Configuration - Development
# This is a development configuration file. DO NOT use in production.

# Application Settings
APP_NAME=BIRD
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Security
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=sqlite:////home/ubuntu/bird-backend/data/bird.db
DATABASE_ECHO=False

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_SMALL=qwen2.5:7b
OLLAMA_MODEL_MEDIUM=qwen3:8b
OLLAMA_MODEL_LARGE=qwen3:14b
OLLAMA_TIMEOUT=300

# ChromaDB Configuration
CHROMADB_PATH=./data/chromadb
CHROMADB_COLLECTION_NAME=bird_intelligence

# Session Configuration
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=lax
SESSION_EXPIRE_SECONDS=86400

# API Configuration
API_V1_STR=/api/v1
API_V2_STR=/api/v2
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000", "http://localhost:8080"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
